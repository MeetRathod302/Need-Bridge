# NeedBridge AI — Environment Configuration
# Copy this to .env and fill in your values before running

# Supabase — get from https://supabase.com/dashboard → Project → Settings → API
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_KEY=YOUR_SERVICE_ROLE_KEY

# Groq — get from https://console.groq.com/keys
GROQ_API_KEY=gsk_YOUR_GROQ_API_KEY

# Web Push VAPID keys — generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=YOUR_VAPID_PUBLIC_KEY
VAPID_PRIVATE_KEY=YOUR_VAPID_PRIVATE_KEY
VAPID_EMAIL=admin@needbridge.in

# App
PORT=3001
ALLOWED_ORIGIN=http://localhost:5173
APP_URL=http://localhost:3001
